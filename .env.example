# Supabase configuration (optional — for database-backed view counts)
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings → API Keys
# 3. Copy your Project URL and publishable key
# 4. Create a .env file (local dev) or set GitHub repo secrets (CI/CD)
#
# Note: The publishable key (sb_publishable_*) is safe to expose in the
# frontend — security is enforced by Row Level Security (RLS) policies.
# NEVER expose the secret key (sb_secret_*) in frontend code.
#
# The Data REST API endpoint is auto-generated at:
#   https://<project_ref>.supabase.co/rest/v1/
# No separate env var needed — the Supabase client handles it.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
